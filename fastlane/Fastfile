# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do
  # Defaults for Xcode 26 / iOS 26.
  #
  # Override in CI when needed:
  # IOS_SIMULATOR_DEVICE="iPhone 17 Pro"
  # IOS_SIMULATOR_OS="26.5"
  simulator_device = ENV.fetch("IOS_SIMULATOR_DEVICE", "iPhone 17")
  simulator_os = ENV.fetch("IOS_SIMULATOR_OS", "latest")
  simulator_destination =
    "platform=iOS Simulator,name=#{simulator_device},OS=#{simulator_os}"

  desc "Run unit tests"
  lane :tests do
    params = {
      package_path: ".",
      scheme: "OpenID4VCI",
      destination: simulator_destination,
      result_bundle: true
    }

    params[:xcargs] = "-skipPackagePluginValidation" if ENV["CI"]

    run_tests(params)
  end

  desc "Fix lint issues"
  lane :run_lint do
    sh "swiftlint lint --fix --config ../.swiftlint.yml --quiet ../"
  end

  desc "Code coverage"
  lane :code_coverage do
    params = {
      package_path: ".",
      scheme: "OpenID4VCI",
      destination: simulator_destination,
      output_directory: "xcov_output",
      result_bundle: true,
      parallel_testing: false,
      xcodebuild_formatter: "xcbeautify",
      xcargs: ENV["CI"] ? "-skipPackagePluginValidation" : nil
    }

    run_tests(params)

    xcov(
      scheme: "OpenID4VCI",
      output_directory: "xcov_output",
      is_swift_package: true,
      minimum_coverage_percentage: 50.0,
      include_targets: "OpenID4VCI"
    )

    sh "open ../xcov_output/index.html" unless ENV["CI"] == "true"
  end

  desc "Builds the package"
  lane :just_build do
    xcodebuild(
      scheme: "OpenID4VCI",
      destination: simulator_destination,
      xcargs: [
        "-skipPackagePluginValidation",
        "-disableAutomaticPackageResolution"
      ].join(" ")
    )
  end

  before_all do
    FileUtils.remove_dir("../xcov_output", true)

    UI.message("Xcode: #{sh('xcodebuild -version', log: false).strip}")
    UI.message("Simulator destination: #{simulator_destination}")
  end
end